# =============================================================================
# WordPress Social Autopilot — environment template
# Copy to `.env` and fill in real values. NEVER commit a real `.env`.
# Every variable here is validated at startup by src/lib/env.ts (Zod). The app
# refuses to boot if any are missing or invalid.
# =============================================================================

# --- Core --------------------------------------------------------------------
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/wordpress_social_autopilot"
# Canonical URL NextAuth uses for callbacks (must match your deployment origin).
NEXTAUTH_URL="http://localhost:3000"
# NextAuth session/JWT signing secret. Generate: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-with-a-long-random-string"
# Public base URL of this app (used to build OAuth redirect URIs).
APP_BASE_URL="http://localhost:3000"

# --- Security ----------------------------------------------------------------
# Shared secret for verifying the WordPress webhook HMAC-SHA256 signature.
# Must match the secret configured in the WordPress webhook plugin.
WEBHOOK_SECRET="replace-with-a-shared-webhook-secret"
# 32-byte key (base64) for AES-256-GCM encryption of OAuth tokens at rest.
# Generate exactly 32 bytes: `openssl rand -base64 32`
TOKEN_ENCRYPTION_KEY="replace-with-32-byte-base64-key"

# --- Dashboard auth (GitHub) -------------------------------------------------
# GitHub OAuth App credentials (Settings → Developer settings → OAuth Apps).
GITHUB_CLIENT_ID="your-github-oauth-client-id"
GITHUB_CLIENT_SECRET="your-github-oauth-client-secret"
# GitHub logins allowed to access the dashboard (comma-separated for multiple).
OWNER_GITHUB_LOGIN="your-github-username"
# Optional: also allow any active member of this GitHub org (needs read:org scope).
OWNER_GITHUB_ORG="your-github-org"

# --- Claude (Anthropic) ------------------------------------------------------
# Anthropic API key for content generation (model: claude-opus-4-8).
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# --- NovaMira MCP (WordPress fallback) ---------------------------------------
# NovaMira MCP endpoint + token used to backfill missing webhook post data.
# The app serves ONE site per deployment: during rollout these carry the DEV
# site's values (see go-live-prompts.md GL-04); the switch to the live site is
# the final gated step (GL-28).
NOVAMIRA_MCP_URL="https://your-novamira-mcp-endpoint.example.com"
NOVAMIRA_MCP_TOKEN="your-novamira-mcp-token"
# The single WordPress site this app is connected to.
WORDPRESS_SITE_URL="https://your-wordpress-site.example.com"

# --- LinkedIn ----------------------------------------------------------------
# LinkedIn OAuth 2.0 app (scope: w_member_social). API version: 202606.
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"

# --- Meta (Facebook + Instagram) ---------------------------------------------
# Meta app credentials (Graph API v25.0). Instagram publishing requires an
# Instagram Business/Creator account linked to a Facebook Page.
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"

# --- X / Twitter -------------------------------------------------------------
# X API v2 OAuth 2.0 (PKCE) client. Scopes: tweet.read tweet.write users.read
# offline.access. Note: X posting is pay-per-use (~$0.20 per link post).
X_CLIENT_ID="your-x-client-id"
X_CLIENT_SECRET="your-x-client-secret"

# --- TikTok ------------------------------------------------------------------
# TikTok Content Posting API v2 client (scopes: video.publish / video.upload).
TIKTOK_CLIENT_KEY="your-tiktok-client-key"
TIKTOK_CLIENT_SECRET="your-tiktok-client-secret"

# --- YouTube / Google --------------------------------------------------------
# Google OAuth client (YouTube Data API v3). NOTE: the public API has no
# community-post endpoint — YouTube content is held for manual posting.
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- Worker / cron (optional; deployment-only) --------------------------------
# Bearer token required by GET|POST /api/worker/tick. Fail-closed: when unset
# the endpoint is disabled (503). Generate: `openssl rand -base64 32`.
# CRON_SECRET="replace-with-a-long-random-string"

# --- Local UI preview (dev only; NEVER set in production) ---
# Set to "true" to bypass GitHub sign-in when running `npm run dev`.
DEV_AUTH_BYPASS="false"
